# Next.js 前端环境配置

# ============ 应用 ============
NEXT_PUBLIC_APP_NAME=AIGCCloud
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============ FastAPI 后端 ============
NEXT_PUBLIC_API_URL=http://localhost:8882

# ============ Parse Server ============
PARSE_APP_ID=BTGAPPId
PARSE_REST_API_KEY=BTGAPIKEY
PARSE_SERVER_URL=http://127.0.0.1:1337/parse

# ============ Web3 联盟链 ============
# Server Actions 使用（不带 NEXT_PUBLIC_）
WEB3_RPC_URL=http://8.130.135.47/btg888/
WEB3_CHAIN_ID=888
WEB3_CHAIN_NAME=联盟链
WEB3_COIN_CONTRACT=0x0000000000000000000000000000000000000000
# 客户端使用（带 NEXT_PUBLIC_）
NEXT_PUBLIC_WEB3_RPC_URL=http://8.130.135.47/btg888/
NEXT_PUBLIC_WEB3_CHAIN_ID=888
NEXT_PUBLIC_WEB3_CHAIN_NAME=联盟链
NEXT_PUBLIC_WEB3_COIN_CONTRACT=0x0000000000000000000000000000000000000000